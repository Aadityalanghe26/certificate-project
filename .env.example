# Sepolia RPC — get one free from Alchemy or Infura
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Private key of the deployer wallet (no 0x prefix needed by hardhat, but include it)
SEPOLIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# After deploying, paste the contract address here
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT

# RPC for the backend to connect to (use Sepolia URL after deploying there)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Same private key used for signing issue transactions from the backend
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Pinata JWT — get from https://app.pinata.cloud/keys
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Etherscan API key — for contract verification on Sepolia
# Get one free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
